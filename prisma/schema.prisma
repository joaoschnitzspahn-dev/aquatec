generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multi-tenant pool maintenance system — Aquatec

enum Role {
  MASTER
  EMPLOYEE
  CUSTOM
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum PoolType {
  FIBRA
  VINIL
  ALVENARIA
}

enum AppointmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  LATE
}

enum VisitStatus {
  PENDING
  STARTED
  COMPLETED
  CANCELLED
}

enum PhotoType {
  ARRIVAL
  FINAL
  GALLERY
  CLIENT_HOME
  PRODUCT
  SIGNATURE
}

enum StockSource {
  CLIENT
  COMPANY
}

enum NotificationType {
  LATE_VISIT
  LOW_STOCK
  NEW_APPOINTMENT
  MISSED_CLIENT
  COMPANY_LOW_STOCK
  GENERAL
}

enum ExpenseCategory {
  FUEL
  PARTS
  TOOLS
  OTHER
}

enum SaleType {
  PRODUCT
  EXTRA_SERVICE
}

enum EquipmentType {
  PUMP
  FILTER
  HEATER
  CHLORINATOR
  LIGHTING
  OTHER
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  clients            Client[]
  products           Product[]
  appointments       Appointment[]
  visits             ServiceVisit[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  expenses           Expense[]
  sales              Sale[]
  checklistTemplates ChecklistTemplate[]
  rolePermissions    RolePermission[]
  reminders          RecurringReminder[]
}

model User {
  id             String    @id @default(cuid())
  companyId      String
  supabaseUserId String?   @unique
  email          String
  name           String
  phone          String?
  role           Role      @default(EMPLOYEE)
  passwordHash   String?
  avatarUrl      String?
  isOnline       Boolean   @default(false)
  lastSeenAt     DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clients          Client[]          @relation("ResponsibleEmployee")
  appointments     Appointment[]
  visits           ServiceVisit[]
  expenses         Expense[]
  sales            Sale[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  customPermissions UserPermission[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([role])
}

model RolePermission {
  id         String @id @default(cuid())
  companyId  String
  role       Role
  permission String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, role, permission])
  @@index([companyId])
}

model UserPermission {
  id         String @id @default(cuid())
  userId     String
  permission String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
}

model Client {
  id                 String       @id @default(cuid())
  companyId          String
  name               String
  phone              String?
  whatsapp           String?
  address            String
  city               String?
  state              String?
  zipCode            String?
  latitude           Float?
  longitude          Float?
  notes              String?
  photoUrl           String?
  poolType           PoolType     @default(FIBRA)
  volumeLiters       Int?
  serviceDays        String[]
  serviceTime        String?
  responsibleId      String?
  status             ClientStatus @default(ACTIVE)
  qrCodeToken        String       @unique @default(cuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  responsible  User?                @relation("ResponsibleEmployee", fields: [responsibleId], references: [id])
  stockItems   ClientStockItem[]
  appointments Appointment[]
  visits       ServiceVisit[]
  equipment    Equipment[]
  reminders    RecurringReminder[]
  sales        Sale[]

  @@index([companyId])
  @@index([status])
  @@index([responsibleId])
  @@index([name])
}

model Product {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  category      String?
  supplier      String?
  purchasePrice Decimal  @default(0) @db.Decimal(10, 2)
  salePrice     Decimal  @default(0) @db.Decimal(10, 2)
  quantity      Decimal  @default(0) @db.Decimal(12, 3)
  minQuantity   Decimal  @default(0) @db.Decimal(12, 3)
  unit          String   @default("un")
  code          String?
  photoUrl      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientStockItems ClientStockItem[]
  usages           VisitProductUsage[]
  saleItems        SaleItem[]

  @@index([companyId])
  @@index([name])
}

model ClientStockItem {
  id          String   @id @default(cuid())
  clientId    String
  productId   String
  quantity    Decimal  @default(0) @db.Decimal(12, 3)
  unit        String   @default("un")
  minQuantity Decimal  @default(1) @db.Decimal(12, 3)
  notes       String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([clientId, productId])
  @@index([clientId])
}

model Appointment {
  id          String            @id @default(cuid())
  companyId   String
  clientId    String
  employeeId  String
  scheduledAt DateTime
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee User          @relation(fields: [employeeId], references: [id])
  visit    ServiceVisit?

  @@index([companyId, scheduledAt])
  @@index([employeeId, scheduledAt])
  @@index([clientId])
  @@index([status])
}

model ServiceVisit {
  id              String      @id @default(cuid())
  companyId       String
  appointmentId   String?     @unique
  clientId        String
  employeeId      String
  status          VisitStatus @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMinutes Int?
  startLatitude   Float?
  startLongitude  Float?
  endLatitude     Float?
  endLongitude    Float?
  observations    String?
  signatureUrl    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appointment Appointment?         @relation(fields: [appointmentId], references: [id])
  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee    User                 @relation(fields: [employeeId], references: [id])
  checklist   ChecklistResponse[]
  readings    WaterReading[]
  products    VisitProductUsage[]
  photos      VisitPhoto[]
  notes       VisitNote[]

  @@index([companyId])
  @@index([clientId])
  @@index([employeeId])
  @@index([status])
}

model ChecklistTemplate {
  id        String   @id @default(cuid())
  companyId String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   ChecklistItem[]
}

model ChecklistItem {
  id         String  @id @default(cuid())
  templateId String
  label      String
  sortOrder  Int     @default(0)
  required   Boolean @default(false)

  template  ChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses ChecklistResponse[]

  @@index([templateId])
}

model ChecklistResponse {
  id        String   @id @default(cuid())
  visitId   String
  itemId    String
  checked   Boolean  @default(false)
  checkedAt DateTime?

  visit ServiceVisit  @relation(fields: [visitId], references: [id], onDelete: Cascade)
  item  ChecklistItem @relation(fields: [itemId], references: [id])

  @@unique([visitId, itemId])
}

model WaterReading {
  id            String   @id @default(cuid())
  visitId       String
  ph            Float?
  chlorine      Float?
  alkalinity    Float?
  temperature   Float?
  notes         String?
  recordedAt    DateTime @default(now())

  visit ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model VisitProductUsage {
  id           String      @id @default(cuid())
  visitId      String
  productId    String
  quantity     Decimal     @db.Decimal(12, 3)
  source       StockSource @default(CLIENT)
  createdAt    DateTime    @default(now())

  visit   ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@index([visitId])
}

model VisitPhoto {
  id        String    @id @default(cuid())
  visitId   String
  type      PhotoType
  url       String
  caption   String?
  createdAt DateTime  @default(now())

  visit ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model VisitNote {
  id        String   @id @default(cuid())
  visitId   String
  content   String
  createdAt DateTime @default(now())

  visit ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

model Equipment {
  id           String        @id @default(cuid())
  clientId     String
  type         EquipmentType
  brand        String?
  model        String?
  serialNumber String?
  installedAt  DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  client       Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  maintenances EquipmentMaintenance[]

  @@index([clientId])
}

model EquipmentMaintenance {
  id          String   @id @default(cuid())
  equipmentId String
  date        DateTime @default(now())
  description String
  cost        Decimal? @db.Decimal(10, 2)

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String          @id @default(cuid())
  companyId   String
  employeeId  String
  category    ExpenseCategory
  description String
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee User    @relation(fields: [employeeId], references: [id])

  @@index([companyId, date])
  @@index([employeeId])
}

model Sale {
  id          String   @id @default(cuid())
  companyId   String
  clientId    String?
  employeeId  String
  type        SaleType
  description String?
  total       Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client   Client?    @relation(fields: [clientId], references: [id])
  employee User       @relation(fields: [employeeId], references: [id])
  items    SaleItem[]

  @@index([companyId, date])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String?
  name      String
  quantity  Decimal @db.Decimal(12, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  companyId String
  userId    String?
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId, read])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
}

model RecurringReminder {
  id           String   @id @default(cuid())
  companyId    String
  clientId     String
  title        String
  frequencyDays Int     @default(7)
  nextRunAt    DateTime
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([companyId, nextRunAt])
}
